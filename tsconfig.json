{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "lib": [
            "esnext",
            "esnext.array",
            "esnext.asynciterable",
            "esnext.symbol"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noImplicitAny": false,
        "target": "ESNEXT",
        "paths": {
            "~components": [
                "./components-jsx/index.ts"
            ],
            "~/*": [
                "./src/*"
            ],
        },
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "jsx": "preserve",
        "allowJs": true,
        "outDir": "whofuckingcaresdude"
    },
    "include": [
        "src/**/*",
        "components-jsx/**/*",
        "eslint.config.mjs"
    ]
}